<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d6" for="edge" attr.name="order" attr.type="long" />
  <key id="d5" for="edge" attr.name="source_id" attr.type="string" />
  <key id="d4" for="edge" attr.name="description" attr.type="string" />
  <key id="d3" for="edge" attr.name="weight" attr.type="double" />
  <key id="d2" for="node" attr.name="source_id" attr.type="string" />
  <key id="d1" for="node" attr.name="description" attr.type="string" />
  <key id="d0" for="node" attr.name="entity_type" attr.type="string" />
  <graph edgedefault="undirected">
    <node id="&quot;IMAGE_9&quot;">
      <data key="d0">"ORI_IMG"</data>
      <data key="d1">"The image is a grayscale icon depicting two stylized human figures, typically used to signify public restrooms. On the left, there is a silhouette of a female figure, characterized by a wider upper body or dress-like shape. To the right, separated by a distinct vertical line or partition, is the silhouette of a male figure, depicted with a more rectangular torso. Both figures are enclosed within a larger, dark rectangular outline, which could represent a doorway or an entrance to a facility. The overall appearance is simple, clear, and highly symbolic, designed for universal recognition."</data>
      <data key="d2">test_runs/test_mmrag_working\images\image_9.jpg</data>
    </node>
    <node id="&quot;FEMALE ICON&quot;">
      <data key="d0">"OBJECT"</data>
      <data key="d1">"A black, stylized silhouette of a human figure with a skirt-like lower body, typically representing a female. It is positioned on the left side of the sign."</data>
      <data key="d2">test_runs/test_mmrag_working\images\image_9.jpg</data>
    </node>
    <node id="&quot;MALE ICON&quot;">
      <data key="d0">"OBJECT"</data>
      <data key="d1">"A black, stylized silhouette of a human figure with a pant-like lower body, typically representing a male. It is positioned on the right side of the sign."</data>
      <data key="d2">test_runs/test_mmrag_working\images\image_9.jpg</data>
    </node>
    <node id="&quot;RESTROOM SIGN&quot;">
      <data key="d0">"OBJECT"</data>
      <data key="d1">"A white background sign with a dark border, featuring two black, stylized human figures (one female, one male) side-by-side, commonly used to indicate a public restroom for both genders."</data>
      <data key="d2">test_runs/test_mmrag_working\images\image_9.jpg</data>
    </node>
    <edge source="&quot;IMAGE_9&quot;" target="&quot;FEMALE ICON&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"Female Icon是从image_9中提取的实体。"</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;IMAGE_9&quot;" target="&quot;MALE ICON&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"Male Icon是从image_9中提取的实体。"</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;IMAGE_9&quot;" target="&quot;RESTROOM SIGN&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"Restroom Sign是从image_9中提取的实体。"</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;FEMALE ICON&quot;" target="&quot;MALE ICON&quot;">
      <data key="d3">9.0</data>
      <data key="d4">"The female icon and male icon are displayed side-by-side on the same sign to indicate a shared facility."</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;FEMALE ICON&quot;" target="&quot;RESTROOM SIGN&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"The female icon is a primary component of the restroom sign."</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;MALE ICON&quot;" target="&quot;RESTROOM SIGN&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"The male icon is a primary component of the restroom sign."</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_9.jpg</data>
      <data key="d6">1</data>
    </edge>
  </graph>
</graphml>

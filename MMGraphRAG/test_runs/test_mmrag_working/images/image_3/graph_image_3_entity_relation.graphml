      <data key="d6">1</data>
    </edge>
    <edge source="&quot;IMAGE_3&quot;" target="&quot;CLIFFS&quot;">
      <data key="d3">10.0</data>
      <data key="d4">"Cliffs是从image_3中提取的实体。"</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_3.jpg</data>
      <data key="d6">1</data>
    </edge>
    <edge source="&quot;IMAGE_3&quot;" target="&quot;FOREST&quot;">

      <data key="d6">1</data>
    </edge>
    <edge source="&quot;WATERFALL&quot;" target="&quot;CANYON&quot;">
      <data key="d3">9.0</data>
      <data key="d4">"The waterfall is a prominent natural feature located within the deep canyon."</data>
      <data key="d5">test_runs/test_mmrag_working\images\image_3.jpg</data>
      <data key="d6">1</data>
